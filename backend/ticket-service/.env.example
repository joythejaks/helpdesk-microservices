APP_PORT=8082

DB_HOST=ticket-db
DB_PORT=5432
DB_USER=ticket
DB_PASSWORD=ticket
DB_NAME=ticket_db

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Must match INTERNAL_SHARED_SECRET on api-gateway. Requests without this
# header are rejected — closes off direct access that bypasses the gateway's
# JWT validation. Generate with: openssl rand -hex 32
INTERNAL_SHARED_SECRET=change-me-to-a-long-random-value