# Server Configuration
APP_PORT=8081
GIN_MODE=release

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=helpdesk_db

# Security
JWT_SECRET=gunakan_string_acak_dan_panjang_disini

# Must match INTERNAL_SHARED_SECRET on api-gateway. Requests without this
# header are rejected — closes off direct access that bypasses the gateway's
# JWT validation. Generate with: openssl rand -hex 32
INTERNAL_SHARED_SECRET=change-me-to-a-long-random-value

# Dev-only: mount /swagger/*any. Leave unset/false in production.
ENABLE_SWAGGER=false

# Per-client-IP token bucket rate limit for /login, /register, /refresh.
AUTH_RATE_LIMIT_RPS=5
AUTH_RATE_LIMIT_BURST=10