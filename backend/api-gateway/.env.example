APP_PORT=8080

JWT_SECRET=your-secret-key-change-this

AUTH_SERVICE_URL=http://auth-service:8081
TICKET_SERVICE_URL=http://ticket-service:8082

# Comma-separated list of allowed CORS origins, e.g. https://app.example.com,https://admin.example.com
# Defaults to "*" (dev only) if unset.
ALLOWED_ORIGINS=*

# Per-client-IP token bucket rate limit.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Must match INTERNAL_SHARED_SECRET on auth-service / ticket-service. Proves
# to those services that a request actually came through this gateway.
# Generate with: openssl rand -hex 32
INTERNAL_SHARED_SECRET=change-me-to-a-long-random-value