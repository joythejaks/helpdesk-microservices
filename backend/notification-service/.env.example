APP_PORT=8083
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
JWT_SECRET=your-secret-key-change-this

# Comma-separated list of allowed WebSocket origins, e.g. https://app.example.com
# Defaults to "*" (dev only) if unset. Non-browser clients (mobile apps) that
# don't send an Origin header are always allowed through.
ALLOWED_ORIGINS=*

# Per-client-IP token bucket rate limit for WebSocket upgrade attempts.
WS_RATE_LIMIT_RPS=5
WS_RATE_LIMIT_BURST=10

# Hard cap on concurrent WebSocket connections.
MAX_WS_CONNECTIONS=1000